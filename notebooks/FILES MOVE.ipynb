import shutil
import os

os.makedirs("models", exist_ok=True)

files = [
    "final_model.pkl",
    "best_threshold.pkl",
    "feature_names.pkl",
    "shap_explainer.pkl"
]

for f in files:
    shutil.copy(
        f"data/processed/{f}",
        f"models/{f}"
    )

print("✅ Model files copied successfully!")